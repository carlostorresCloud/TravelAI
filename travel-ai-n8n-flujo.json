    {
      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Tu Plan de Viaje a Medida</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n\n  <main class=\"travel-wrapper\">\n    <div class=\"agency-badge\">Tu Plan de Viaje a Medida</div>\n    \n    <div class=\"itinerary-container\">\n      {{ $json.html }}\n    </div>\n  </main>\n\n</body>\n</html>\n\n<style>\n* {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nbody {\n  background-color: #fcfbfa;\n  font-family: 'Plus Jakarta Sans', sans-serif;\n  color: #2c3e50;\n  line-height: 1.7;\n  padding: 40px 20px;\n}\n\n.travel-wrapper {\n  max-width: 800px;\n  margin: 0 auto;\n  background-color: #ffffff;\n  padding: 48px 56px;\n  border-radius: 16px;\n  box-shadow: 0 4px 20px rgba(184, 172, 160, 0.15);\n  border: 1px solid #f1eeea;\n}\n\n.agency-badge {\n  text-align: center;\n  font-size: 12px;\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  color: #c87d55;\n  font-weight: 600;\n  margin-bottom: 24px;\n}\n\n.itinerary-container {\n  text-align: left;\n}\n\n.itinerary-container h1 {\n  font-family: 'Playfair Display', serif;\n  color: #1a2a3a;\n  font-size: 36px;\n  font-weight: 700;\n  line-height: 1.3;\n  text-align: center;\n  margin-bottom: 32px;\n}\n\n.itinerary-container h2 {\n  font-family: 'Playfair Display', serif;\n  color: #c87d55;\n  font-size: 22px;\n  font-weight: 600;\n  margin-top: 36px;\n  margin-bottom: 16px;\n  border-bottom: 1px solid #f5ede6;\n  padding-bottom: 8px;\n}\n\n.itinerary-container h3 {\n  font-size: 16px;\n  font-weight: 600;\n  color: #1a2a3a;\n  margin-top: 20px;\n  margin-bottom: 8px;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.itinerary-container p {\n  font-size: 15px;\n  color: #4a5568;\n  margin-bottom: 16px;\n}\n\n.itinerary-container ul, \n.itinerary-container ol {\n  margin-bottom: 24px;\n  padding-left: 24px;\n}\n\n.itinerary-container li {\n  font-size: 15px;\n  color: #4a5568;\n  margin-bottom: 8px;\n}\n\n.itinerary-container strong {\n  color: #1a2a3a;\n  font-weight: 600;\n}\n\n@media (max-width: 600px) {\n  body {\n    padding: 16px 8px;\n  }\n  .travel-wrapper {\n    padding: 32px 24px;\n  }\n  .itinerary-container h1 {\n    font-size: 28px;\n  }\n  .itinerary-container h2 {\n    font-size: 20px;\n  }\n}\n</style>"
