    {
      "parameters": {
        "jsCode": "// Convierte el itinerario en markdown (generado por la IA) a HTML.\n// La entrada ya es texto markdown plano, NO un string JSON.\nfunction markdownToHtml(text) {\n  if (!text) return '';\n  const lines = String(text).split('\\n');\n  let html = '';\n  let inList = false;\n\n  const closeList = () => {\n    if (inList) { html += '</ul>'; inList = false; }\n  };\n\n  for (const rawLine of lines) {\n    let line = rawLine.trim();\n\n    // Negritas: **texto** -> <strong>texto</strong>\n    line = line.replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>');\n    // Enlaces: [texto](url) -> <a href=\"url\">texto</a>\n    line = line.replace(/\\[(.*?)\\]\\((.*?)\\)/g, '<a href=\"$2\">$1</a>');\n\n    if (line === '') { closeList(); continue; }\n\n    if (line.startsWith('### ')) {\n      closeList();\n      html += '<h3>' + line.slice(4) + '</h3>';\n    } else if (line.startsWith('## ')) {\n      closeList();\n      html += '<h2>' + line.slice(3) + '</h2>';\n    } else if (line.startsWith('# ')) {\n      closeList();\n      html += '<h1>' + line.slice(2) + '</h1>';\n    } else if (/^(\\d+\\.|[-*])\\s+/.test(line)) {\n      if (!inList) { html += '<ul>'; inList = true; }\n      html += '<li>' + line.replace(/^(\\d+\\.|[-*])\\s+/, '') + '</li>';\n    } else {\n      closeList();\n      html += '<p>' + line + '</p>';\n    }\n  }\n  closeList();\n  return html;\n}\n\nconst inputString = $('Generador de planes de viaje').first().json.output;\nconst html = markdownToHtml(inputString);\n\nreturn [{ json: { html } }];"
      },
